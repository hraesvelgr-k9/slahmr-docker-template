# ============================================================
# SLAHMR Docker – environment variables
# Copy this file to .env and adjust as needed.
# ============================================================

# ------------------------------------------------------------
# Build / image
# ------------------------------------------------------------
DOCKERFILE_PATH=Dockerfile
IMAGE_NAME=slahmr
IMAGE_TAG=cu124_pyt240

# ------------------------------------------------------------
# Container
# ------------------------------------------------------------
CONTAINER_NAME=slahmr
CONTAINER_SHM_SIZE=16gb

# ------------------------------------------------------------
# GPU
# ------------------------------------------------------------
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility,video
TORCH_CUDA_ARCH_LIST=6.0;6.1;7.0;7.5;8.0;8.6;8.9;9.0+PTX

# ------------------------------------------------------------
# Paths on host  (relative to project root)
# ------------------------------------------------------------
HOST_SLAHMR_DIR=./workspace/slahmr
HOST_SCRIPTS_DIR=./scripts
HOST_CUSTOM_CFG_FILE=./configs/custom.yaml
HOST_VIDEO_CFG_FILE=./configs/video.yaml
HOST_DATA_DIR=./data

# ------------------------------------------------------------
# Paths in container
# ------------------------------------------------------------
CONTAINER_SLAHMR_DIR=/workspace/slahmr
CONTAINER_CUSTOM_CFG_FILE=/workspace/slahmr/slahmr/confs/data/custom.yaml
CONTAINER_VIDEO_CFG_FILE=/workspace/slahmr/slahmr/confs/data/video.yaml
CONTAINER_DATA_DIR=/workspace/data

# ------------------------------------------------------------
# Runtime defaults
# ------------------------------------------------------------
DATA_SPLIT=val
RUN_OPT=True
RUN_VIS=True
